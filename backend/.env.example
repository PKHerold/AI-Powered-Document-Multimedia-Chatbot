# API Keys
GROQ_API_KEY=your_groq_api_key_here

# MongoDB
MONGODB_URL=mongodb://localhost:27017
DB_NAME=docqa

# App Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# FFmpeg path
# Windows: C:/ffmpeg/bin/ffmpeg.exe
# Linux/Mac: ffmpeg
FFMPEG_PATH=ffmpeg
